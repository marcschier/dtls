# EditorConfig for the DTLS library.
# Security-conscious analyzer severities, Allman braces, 100-column lines.
root = true

##########################################
# All files
##########################################
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

[*.{json,yml,yaml,csproj,props,targets,slnx}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

##########################################
# C# code style
##########################################
[*.cs]
indent_size = 4
max_line_length = 100

# Allman braces: every brace on a new line.
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# Indentation
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = one_less_than_current

# Spacing
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_method_call_parameter_list_parentheses = false

# Wrapping
csharp_preserve_single_line_statements = false
csharp_preserve_single_line_blocks = true

# Always require braces (defense against goto-fail style bugs).
csharp_prefer_braces = true:error

# Namespaces / usings
csharp_style_namespace_declarations = file_scoped:warning
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:warning

# 'this.' qualification not required
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# var preferences: prefer explicit types for clarity/auditability.
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Modern language features
csharp_style_expression_bodied_methods = false:silent
csharp_style_expression_bodied_properties = true:silent
csharp_prefer_simple_using_statement = true:suggestion
csharp_style_prefer_readonly_struct = true:suggestion
csharp_style_prefer_readonly_struct_member = true:suggestion
dotnet_style_readonly_field = true:warning
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning
csharp_prefer_static_local_function = true:warning
dotnet_style_prefer_collection_expression = when_types_loosely_match:suggestion

# Pattern matching / null
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:warning

# Naming. Constants and static readonly fields are PascalCase; private instance
# fields are _camelCase. The more specific (modifier) rules are listed first so they
# take precedence over the private-instance rule.
dotnet_naming_style.pascal_case.capitalization = pascal_case
dotnet_naming_style.underscore_prefix.capitalization = camel_case
dotnet_naming_style.underscore_prefix.required_prefix = _

dotnet_naming_symbols.constant_fields.applicable_kinds = field
dotnet_naming_symbols.constant_fields.applicable_accessibilities = *
dotnet_naming_symbols.constant_fields.required_modifiers = const
dotnet_naming_rule.constant_fields_pascal.symbols = constant_fields
dotnet_naming_rule.constant_fields_pascal.style = pascal_case
dotnet_naming_rule.constant_fields_pascal.severity = warning

dotnet_naming_symbols.static_readonly_fields.applicable_kinds = field
dotnet_naming_symbols.static_readonly_fields.applicable_accessibilities = *
dotnet_naming_symbols.static_readonly_fields.required_modifiers = static,readonly
dotnet_naming_rule.static_readonly_pascal.symbols = static_readonly_fields
dotnet_naming_rule.static_readonly_pascal.style = pascal_case
dotnet_naming_rule.static_readonly_pascal.severity = warning

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_prefix
dotnet_naming_rule.private_fields_underscore.severity = warning

# Style rules as build errors where they protect correctness.
dotnet_diagnostic.IDE0011.severity = warning   # add braces
dotnet_diagnostic.IDE0161.severity = warning   # file-scoped namespace

# Require the MIT copyright file header on every C# file (IDE0073).
file_header_template = Copyright (c) marcschier. All rights reserved.\nLicensed under the MIT License. See LICENSE in the project root for license information.
dotnet_diagnostic.IDE0073.severity = warning   # require file header

##########################################
# Security analyzers -> error
##########################################
dotnet_diagnostic.CA5350.severity = error   # weak crypto algorithm
dotnet_diagnostic.CA5351.severity = error   # broken crypto algorithm
dotnet_diagnostic.CA5358.severity = warning # review cipher mode usage
dotnet_diagnostic.CA5359.severity = error   # do not disable cert validation
dotnet_diagnostic.CA5360.severity = error   # dangerous methods in deserialization
dotnet_diagnostic.CA5364.severity = error   # deprecated security protocols
dotnet_diagnostic.CA5386.severity = warning # hardcoded SecurityProtocolType
dotnet_diagnostic.CA5397.severity = error   # deprecated SslProtocols
dotnet_diagnostic.CA5398.severity = warning # hardcoded SslProtocols
dotnet_diagnostic.CA2300.severity = error   # insecure deserializer BinaryFormatter
dotnet_diagnostic.CA2301.severity = error
dotnet_diagnostic.CA2302.severity = error
dotnet_diagnostic.CA3075.severity = error   # insecure DTD processing
dotnet_diagnostic.CA3077.severity = error
dotnet_diagnostic.CA5390.severity = error   # do not hard-code encryption key
dotnet_diagnostic.CA5394.severity = warning # do not use insecure randomness

# Correctness / reliability that matter for a network security library.
dotnet_diagnostic.CA1062.severity = warning # validate public arguments
dotnet_diagnostic.CA1305.severity = warning # specify IFormatProvider
dotnet_diagnostic.CA2007.severity = warning # ConfigureAwait(false) in library code
dotnet_diagnostic.CA2016.severity = warning # forward CancellationToken
dotnet_diagnostic.CA1849.severity = warning # call async methods in async context

##########################################
# Tame noisy, non-security rules
##########################################
# Modern throw-helpers (ThrowIfNull/ThrowIf*) do not exist on netstandard2.1; we
# multi-target down to it, so these cannot be satisfied uniformly.
dotnet_diagnostic.CA1510.severity = none      # ArgumentNullException.ThrowIfNull
dotnet_diagnostic.CA1511.severity = none      # ArgumentException.ThrowIfNullOrEmpty
dotnet_diagnostic.CA1512.severity = none      # ArgumentOutOfRangeException.ThrowIf*
dotnet_diagnostic.CA1513.severity = none      # ObjectDisposedException.ThrowIf
dotnet_diagnostic.CA1303.severity = none      # do not require localized exception text
dotnet_diagnostic.CA1031.severity = suggestion # catch general exception (sometimes valid)
dotnet_diagnostic.CA1716.severity = none      # identifier matches keyword
dotnet_diagnostic.CA1724.severity = none      # type name conflicts with namespace
dotnet_diagnostic.RCS1090.severity = none     # ConfigureAwait handled by CA2007

##########################################
# Test projects: relax library-only rules
##########################################
[tests/**.cs]
dotnet_diagnostic.CA2007.severity = none   # ConfigureAwait not needed in tests
dotnet_diagnostic.CA1707.severity = none   # underscores in test method names
dotnet_diagnostic.CA1062.severity = none
dotnet_diagnostic.CA5394.severity = none   # non-crypto randomness allowed in tests
dotnet_diagnostic.CA1515.severity = none   # public test types
dotnet_diagnostic.CA1812.severity = none

##########################################
# Samples: relax library-only rules
##########################################
[samples/**.cs]
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.CA1303.severity = none
dotnet_diagnostic.CA1812.severity = none
