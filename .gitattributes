# Normalize line endings to LF in the repository; check out native on Windows.
* text=auto

*.cs    text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.slnx  text eol=lf
*.sln   text eol=crlf
*.sh    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.editorconfig text eol=lf

# Binary
*.snk   binary
*.pfx   binary
*.png   binary
