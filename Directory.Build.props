<Project>

  <!-- Common settings applied to every project in the repository. -->
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <InvariantGlobalization>true</InvariantGlobalization>

    <!-- Quality gates -->
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest-all</AnalysisLevel>
    <CodeAnalysisTreatWarningsAsErrors>true</CodeAnalysisTreatWarningsAsErrors>

    <!-- Reproducible builds -->
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <!-- Security: never embed the build machine path. -->
    <PathMap Condition="'$(CI)' == 'true'">$(MSBuildThisFileDirectory)=/_/</PathMap>
  </PropertyGroup>

  <!-- Strong naming. The shipping library and its friend test assemblies are signed with a
       committed key: a strong-name key is an identity, not a secret, so committing it keeps
       builds reproducible and requires no CI/secret wiring. DtlsPublicKey is the full public
       key of eng/Dtls.snk (token 3f0c2131dbeee25d); the library's InternalsVisibleTo
       declarations reference it so the signed friend test assemblies retain internals access.
       SignAssembly itself is opted in per-project (the shipping library and those two friends);
       samples and the public-API-only test projects stay unsigned. -->
  <PropertyGroup>
    <StrongNameKeyPath>$(MSBuildThisFileDirectory)eng\Dtls.snk</StrongNameKeyPath>
    <DtlsPublicKey></DtlsPublicKey>
  </PropertyGroup>

  <!-- Security-conscious analyzers shared by all projects. -->
  <ItemGroup>
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="all" />
    <PackageReference Include="Roslynator.Formatting.Analyzers" PrivateAssets="all" />
    <PackageReference Include="Microsoft.VisualStudio.Threading.Analyzers" PrivateAssets="all" />
  </ItemGroup>

  <!-- Reproducible, Git-based versioning for every project (assembly + package versions). -->
  <ItemGroup>
    <PackageReference Include="Nerdbank.GitVersioning" PrivateAssets="all" />
  </ItemGroup>

</Project>
